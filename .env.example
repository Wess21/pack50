# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# Database Configuration
DATABASE_URL=postgresql://pack50:dev_password@localhost:15432/pack50

# Redis Configuration
REDIS_URL=redis://:dev_password@localhost:16379

# AI Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Application Configuration
NODE_ENV=development
PORT=3000

# Webhook Configuration
# Optional - leave empty to disable webhook delivery
WEBHOOK_URL=https://your-crm-system.com/webhook/endpoint

# Admin Panel Security (Phase 4)
# Generate ENCRYPTION_KEY with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here-32-bytes
JWT_SECRET=your-jwt-secret-min-32-characters-long
DEFAULT_ADMIN_PASSWORD=changeme
